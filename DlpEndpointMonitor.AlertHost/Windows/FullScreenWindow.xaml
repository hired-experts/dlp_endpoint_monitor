<Window x:Class="DlpEndpointMonitor.AlertHost.Windows.FullScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DlpEndpointMonitor.AlertHost.Controls"
        Title="DLP Alert"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="OnClicked">
    <!--
        Covers its assigned monitor edge-to-edge (explicit Left/Top/Width/Height from the
        caller-supplied screen bounds in code-behind - one instance is constructed per connected
        monitor, see App.ShowAlertWindow - not WindowState=Maximized, which on a WindowStyle=None
        window sizes to the work area and leaves a taskbar-shaped gap) filled solid with the one
        shared brand blue (HeaderBrush - same color for every AlertSeverity, see
        Resources/Colors.xaml), with the same rounded AlertBox centered on top in white - one
        continuous color from the screen edge through the header band, breaking to white for the
        body. Severity is conveyed by AlertBox's own icon, not by this backdrop's color. Auto-closes
        after DurationSeconds, on a click anywhere on the backdrop, or when the matching instance on
        another monitor is dismissed first.
    -->
    <Grid x:Name="Backdrop" Background="{DynamicResource HeaderBrush}">
        <controls:AlertBox x:Name="Box" Width="520" MaxWidth="720" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>

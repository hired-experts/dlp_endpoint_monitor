<Window x:Class="DlpEndpointMonitor.AlertHost.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DlpEndpointMonitor.AlertHost.Controls"
        Title="DLP Alert"
        MaxWidth="320"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <!--
        Transient corner toast: anchored bottom-right (common OS toast convention) by
        PositionBottomRight in code-behind once SizeToContent has measured the actual size.
        Auto-closes after DurationSeconds, or on the X button in the header (ShowCloseButton, set
        in code-behind) - NOT on a click anywhere on the toast, since that made it impossible to
        select/copy the message or click the ID's Copy button without accidentally dismissing it.
        AlertBox is used directly (no extra wrapping Border) - it is already the complete rounded
        box, and a fixed 360px Width plus a second layer of margin/background was what made this
        look oversized for a short one-line toast message; MaxWidth + SizeToContent lets it shrink
        to fit.

        DropShadowEffect: AllowsTransparency="True" windows lose WPF's normal OS-drawn drop
        shadow, and the card's own 1px light-gray BorderBrush alone isn't enough separation when
        the toast floats over a white browser/app window behind it - a white-on-white toast could
        go unnoticed entirely otherwise. This is set here (not inside AlertBox itself) so a window
        that wraps AlertBox in an outer card could apply its own shadow to that outer shape instead
        without a duplicate/mismatched shadow on AlertBox's own inner sub-shape.
    -->
    <controls:AlertBox x:Name="Box" Margin="12">
        <controls:AlertBox.Effect>
            <DropShadowEffect Color="Black" Opacity="0.28" BlurRadius="24" ShadowDepth="3" Direction="270"/>
        </controls:AlertBox.Effect>
    </controls:AlertBox>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Header color - ONE brand blue for every AlertSeverity, not a per-severity traffic-light
        scheme (no more red-for-Blocked/yellow-for-Warning). Severity is now conveyed entirely by
        the icon AlertBox renders in its header (see AlertBox.xaml/.cs's InfoIcon/WarningIcon/
        BlockedIcon), never by color. Value is the control center's "primary" token verbatim
        (dlp_v2/controlcenter/app/globals.css, HSL 198 64% 48%, hex #2D9CCA) - the brand's own
        CTA/interactive blue, already a calm, moderate intensity that reads fine full-bleed on
        FullScreenWindow's edge-to-edge backdrop too.
    -->
    <SolidColorBrush x:Key="HeaderBrush" Color="#FF2D9CCA"/>

    <!-- Header text AND icon both use this over the color band above. -->
    <SolidColorBrush x:Key="SeverityForegroundBrush" Color="#FFFFFFFF"/>

    <!--
        Shared surface/background/body tokens, taken verbatim from the same globals.css :root
        block (rule 1 - these are all already moderate, no rule-2 adaptation needed):
          card             (0 0% 100%)   #FFFFFF
          background       (240 23% 97%) #F7F7FA
          foreground       (237 56% 8%)  #090A20
          border / input   (220 13% 91%) #E5E7EB
          muted-foreground (220 9% 46%)  #6B7280
    -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF7F7FA"/>
    <SolidColorBrush x:Key="BodyTextBrush" Color="#FF090A20"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFE5E7EB"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#FF6B7280"/>

</ResourceDictionary>
